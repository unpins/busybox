Use thin archives instead of `ld -r` for kbuild's per-directory aggregation.

With fat-LTO bitcode, `cc -r` (kbuild's default since the top Makefile
sets LD = $(CC) -nostdlib) engages lto-plugin which fails to write a
relocatable output ("final close failed: invalid operation"). Thin
archives sidestep this — they don't trigger LTO at aggregation time;
the final link via gcc loads lto-plugin which scans archive members
and pulls in their bitcode, preserving full chain-LTO across the
entire tree (same approach as the Linux kernel's CONFIG_THIN_ARCHIVES).

--- a/scripts/Makefile.build
+++ b/scripts/Makefile.build
@@ -253,11 +253,9 @@ $(sort $(subdir-obj-y)): $(subdir-ym) ;
 # Rule to compile a set of .o files into one .o file
 #
 ifdef builtin-target
-quiet_cmd_link_o_target = LD      $@
-# If the list of objects to link is empty, just create an empty built-in.o
-# -nostdlib is added to make "make LD=gcc ..." work (some people use that)
+quiet_cmd_link_o_target = AR      $@
 cmd_link_o_target = $(if $(strip $(obj-y)),\
-		$(LD) -nostdlib $(ld_flags) -r -o $@ $(filter $(obj-y), $^),\
+		rm -f $@; $(AR) cDPrsT $@ $(filter $(obj-y), $^),\
 		rm -f $@; $(AR) rcs $@)

 $(builtin-target): $(obj-y) FORCE
